# ============================================================
# JRD — Hetzner production .env (انسخه إلى .env وعبّئه)
# ------------------------------------------------------------
# لا ترفع .env إلى Git أبداً.
# في الإعداد الأوّل، شغّل لتوليد أسرار قوية:
#   openssl rand -hex 32   # لكل من JWT_SECRET / INTERNAL_API_KEY ...
# ============================================================

# ---- أساسي ----
NODE_ENV=production
PORT=3001

# المسارات (لا تغيّرها — مضبوطة في docker-compose.yml)
DATA_DIR=/data
AUTH_DIR=/data/auth_sessions
GMSG_BROWSER_DATA=/data/gmsg-browser-data

# ---- المصادقة الداخلية (backend ↔ bot ↔ scrapers) ----
INTERNAL_API_KEY=CHANGE_ME_openssl_rand_hex_32

# ---- بوت واتساب ----
BOT_PORT=3100
BOT_HOST=0.0.0.0
BOT_URL=http://127.0.0.1:3100
BOT_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ---- Google Messages scraper ----
GMSG_PORT=3101
GMSG_HOST=0.0.0.0
GMSG_HEADLESS=true
GMSG_TARGET_CONTACT=KUVEYT TURK
GMSG_AUTOSTART=true

# ---- البنك (SMS Forwarder webhook) ----
# secret إلزامي على الإنتاج — يُوضع في URL على تطبيق SMS Forwarder:
#   https://new.ahlacard.net/api/bank/sms-webhook?secret=...
SMS_WEBHOOK_SECRET=CHANGE_ME_openssl_rand_hex_24

# ---- SMM proxy (Cloudflare Worker) ----
SMM_PROXY_URL=
SMM_PROXY_SECRET=

# ---- JWT (سيُستخدم في المرحلة 4 — المصادقة) ----
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# ============================================================
# Hetzner Storage Box (للنسخ الاحتياطي اليومي)
# ------------------------------------------------------------
# بعد إنشاء Storage Box من لوحة Hetzner:
#   STORAGE_BOX_USER  = u123456-sub1
#   STORAGE_BOX_HOST  = u123456.your-storagebox.de
#   STORAGE_BOX_PORT  = 23           (افتراضي Hetzner)
#   STORAGE_BOX_PATH  = /home/backups/jrd
#   STORAGE_BOX_KEY   = /root/.ssh/storage_box  (مسار مفتاح SSH على الخادم)
# ============================================================
STORAGE_BOX_USER=
STORAGE_BOX_HOST=
STORAGE_BOX_PORT=23
STORAGE_BOX_PATH=/home/backups/jrd
STORAGE_BOX_KEY=/root/.ssh/storage_box
