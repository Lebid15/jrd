# بيانات تسجيل الدخول لموقع bayi.alayatl.com
# هذه قيم وهمية فقط — البيانات الحقيقية تُحفظ في .env (لا يُرفع للـ git)
# أو تُمرَّر عبر إعدادات API في الواجهة (لكل بند على حدة).
BAYI_PHONE=5XXXXXXXXX
BAYI_PASSWORD=YOUR_PASSWORD_HERE
BAYI_PIN=111111

# اضبط false لرؤية المتصفح أثناء التشغيل (مفيد للتشخيص)
# اضبط true للتشغيل في الخلفية بدون نافذة
HEADLESS=false

# مهلة بالميلي ثانية لانتظار تحميل الصفحات
NAV_TIMEOUT_MS=30000
