# جهة الاتصال المستهدفة كما تظهر في عمود المحادثات في Google Messages Web
# (مطابقة جزئية غير حسّاسة لحالة الأحرف — افتراضياً: KUVEYT TURK)
TARGET_CONTACT=KUVEYT TURK

# headless=false لازم في أوّل تشغيل (لمسح QR). بعد الاقتران الجلسة تُحفظ.
HEADLESS=false

# مكان حفظ جلسة المتصفّح (Persistent Context). لا تحذفه أو ستحتاج لإعادة الاقتران.
# يُحلّ نسبياً إلى مجلد messages-scraper/ لو تركته فارغاً.
BROWSER_DATA_DIR=

# مهلة الانتظار لمسح QR (بالثواني). ضع رقماً كبيراً في أوّل مرّة.
PAIRING_TIMEOUT_SEC=300

# مهلة عامة للتنقّل (ms)
NAV_TIMEOUT_MS=45000
