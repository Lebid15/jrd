# Production settings
NODE_ENV=production

# Persistent data directory (DB + uploads + browser-data).
# In Railway, mount a Volume at this path.
DATA_DIR=/data

# Server port (Railway sets PORT automatically; locally defaults to 3001)
PORT=3001

# Scraper timeout (ms) — bayi.alayatl scraper can take 30-60s
SCRAPER_TIMEOUT_MS=180000
